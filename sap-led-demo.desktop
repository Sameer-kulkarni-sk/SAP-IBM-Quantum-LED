[Desktop Entry]
Version=1.1
Name=SAP LED Demo
Comment=SAP LED Matrix Display with Physical Hardware
Icon=/usr/share/icons/rasqberry/sensehat-icon.png
Type=Application
Categories=RasQberry;
Exec=bash -c 'export HOME=${HOME:-/home/rasqberry}; /home/rasqberry/rq_sap_led_demo.sh'
Terminal=true
StartupNotify=true
Keywords=SAP;LED;visualization;quantum;
X-GNOME-TextColor=#000000
TryExec=bash
NoDisplay=false